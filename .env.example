NODE_ENV=development
PORT=5000
API_VERSION=v1

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qr_pos_db?schema=public"

JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RESET_PASSWORD_SECRET=change_this_reset_secret_in_production
RESET_PASSWORD_EXPIRES_IN=15m

CLIENT_URL=http://localhost:5173
COOKIE_SECRET=change_this_cookie_secret_in_production

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

LOG_LEVEL=info
